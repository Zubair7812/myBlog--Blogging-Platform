<%- include('partials/header') %>

    <div class="chat-container">
        <!-- Sidebar -->
        <div class="chat-sidebar">
            <div class="sidebar-header">
                <h3>Messages</h3>
            </div>
            <div class="contacts-list">
                <% if(contacts.length> 0) { %>
                    <% contacts.forEach(contact=> { %>
                        <a href="/chat/<%= contact.user.username %>"
                            class="contact-item <%= activeChat && activeChat.username === contact.user.username ? 'active' : '' %>">
                            <img src="/thumbnails/<%= contact.user.dp %>" onerror="this.src='/images/user-icon.png'"
                                alt="User">
                            <div class="contact-info">
                                <span class="contact-name">
                                    <%= contact.user.fullname || contact.user.username %>
                                </span>
                                <span class="contact-preview">
                                    <%= contact.lastMessage.sender.username===user ? 'You: ' : '' %>
                                        <%= contact.lastMessage.content.substring(0, 20) %>...
                                </span>
                            </div>
                        </a>
                        <% }) %>
                            <% } else { %>
                                <p style="padding: 1rem; color: var(--text-light); font-size: 0.9rem;">No conversations
                                    yet. Visit a profile to start chatting!</p>
                                <% } %>
            </div>
        </div>

        <!-- Main Chat Area -->
        <div class="chat-main">
            <% if(activeChat) { %>
                <div class="chat-header">
                    <div style="display: flex; align-items: center;">
                        <img src="/thumbnails/<%= activeChat.dp %>" onerror="this.src='/images/user-icon.png'"
                            style="width: 40px; height: 40px; border-radius: 50%; margin-right: 1rem; object-fit: cover;">
                        <div>
                            <h3 style="margin: 0; font-size: 1.1rem;">
                                <%= activeChat.fullname %>
                            </h3>
                            <span style="font-size: 0.8rem; color: var(--text-light);">@<%= activeChat.username %>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="messages-area" id="messagesArea">
                    <% messages.forEach(msg=> { %>
                        <div
                            class="message-bubble <%= msg.sender.equals(currentUserDetails._id) ? 'sent' : 'received' %>">
                            <% if(msg.type==='link' && msg.metadata) { %>
                                <div class="shared-content">
                                    <strong>Shared a Story:</strong><br>
                                    <a href="<%= msg.content %>" target="_blank"
                                        style="color: white; text-decoration: underline;">View Story</a>
                                </div>
                                <% } else { %>
                                    <%= msg.content %>
                                        <% } %>
                                            <div class="msg-time">
                                                <%= new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit' ,
                                                    minute:'2-digit'}) %>
                                            </div>
                        </div>
                        <% }) %>
                </div>

                <div class="chat-input-area">
                    <form id="chatForm" style="display: flex; gap: 1rem; width: 100%;">
                        <input type="text" id="msgInput" placeholder="Type a message..." required autocomplete="off">
                        <button type="submit" class="submit-btn"><i class="fa-regular fa-paper-plane"></i></button>
                    </form>
                </div>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fa-regular fa-comments"
                            style="font-size: 4rem; color: #ddd; margin-bottom: 1rem;"></i>
                        <h2>Select a conversation</h2>
                        <p>Choose a contact from the left to start chatting.</p>
                    </div>
                    <% } %>
        </div>
    </div>

    <style>
        /* Chat Specific Styles */
        .chat-container {
            display: grid;
            grid-template-columns: 300px 1fr;
            height: calc(100vh - 80px);
            /* Adjust for header */
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            box-shadow: var(--shadow-sm);
        }

        .chat-sidebar {
            border-right: 1px solid var(--border-color);
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }

        .contacts-list {
            padding: 1rem 0;
        }

        .contact-item {
            display: flex;
            align-items: center;
            padding: 1rem 1.5rem;
            transition: 0.2s;
            cursor: pointer;
        }

        .contact-item:hover,
        .contact-item.active {
            background: #f8f9fa;
            border-left: 4px solid var(--primary-color);
        }

        .contact-item img {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            margin-right: 1rem;
            object-fit: cover;
        }

        .contact-info {
            display: flex;
            flex-direction: column;
        }

        .contact-name {
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--text-color);
        }

        .contact-preview {
            font-size: 0.8rem;
            color: var(--text-light);
        }

        .chat-main {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .chat-header {
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border-color);
            background: #fff;
        }

        .messages-area {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
            background: #fdfdfd;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .message-bubble {
            max-width: 60%;
            padding: 0.8rem 1.2rem;
            border-radius: 1rem;
            position: relative;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .message-bubble.sent {
            align-self: flex-end;
            background: var(--primary-color);
            color: white;
            border-bottom-right-radius: 2px;
        }

        .message-bubble.received {
            align-self: flex-start;
            background: #eaeff2;
            color: var(--text-color);
            border-bottom-left-radius: 2px;
        }

        .msg-time {
            font-size: 0.7rem;
            opacity: 0.7;
            margin-top: 0.3rem;
            text-align: right;
        }

        .chat-input-area {
            padding: 1.5rem;
            background: white;
            border-top: 1px solid var(--border-color);
        }

        #msgInput {
            flex: 1;
            padding: 1rem;
            border: 1px solid var(--border-color);
            border-radius: 50px;
            background: #f8f9fa;
        }

        #msgInput:focus {
            outline: none;
            border-color: var(--primary-color);
            background: white;
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--text-light);
        }

        .shared-content {
            background: rgba(255, 255, 255, 0.2);
            padding: 0.5rem;
            border-radius: 4px;
            margin-bottom: 0.5rem;
        }

        @media(max-width: 768px) {
            .chat-container {
                grid-template-columns: 1fr;
                height: calc(100vh - 120px);
            }

            .chat-sidebar {
                display: <%=activeChat ? 'none': 'block' %>;
            }

            .chat-main {
                display: <%=activeChat ? 'flex': 'none' %>;
            }
        }
    </style>

    <% if(activeChat) { %>
        <script>
            const chatForm = document.getElementById('chatForm');
            const msgInput = document.getElementById('msgInput');
            const messagesArea = document.getElementById('messagesArea');
            const recipientUsername = '<%= activeChat.username %>';

            // Check for share link
            const urlParams = new URLSearchParams(window.location.search);
            const sharePath = urlParams.get('share');
            if (sharePath) {
                msgInput.value = "Check out this story: " + window.location.origin + sharePath;
            }

            // Auto scroll to bottom
            messagesArea.scrollTop = messagesArea.scrollHeight;

            // Send Message
            chatForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const content = msgInput.value;
                if (!content) return;

                try {
                    const res = await fetch('/api/chat/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ recipientUsername, content })
                    });
                    const data = await res.json();

                    if (data.status === 'sent') {
                        appendMessage(data.message, 'sent');
                        msgInput.value = '';
                        messagesArea.scrollTop = messagesArea.scrollHeight;
                    }
                } catch (err) { console.error(err); }
            });

            function appendMessage(msg, type) {
                const div = document.createElement('div');
                div.className = `message-bubble ${type}`;
                div.innerHTML = `${msg.content} <div class="msg-time">Just now</div>`;
                messagesArea.appendChild(div);
            }

            // Polling
            let lastMsgId = '<%= messages.length > 0 ? messages[messages.length-1]._id : "" %>';

            async function pollMessages() {
                try {
                    const res = await fetch(`/api/chat/${recipientUsername}/poll?lastId=${lastMsgId}`);
                    const data = await res.json();

                    if (data.messages && data.messages.length > 0) {
                        data.messages.forEach(msg => {
                            // Only append if it's from the other person (sent ones are already appended locally)
                            if (msg.sender !== '<%= currentUserDetails._id %>') {
                                appendMessage(msg, 'received');
                                lastMsgId = msg._id;
                            } else {
                                // If it's my message (from another tab?), update ID
                                lastMsgId = msg._id;
                            }
                        });
                        if (data.messages.length > 0) messagesArea.scrollTop = messagesArea.scrollHeight;
                    }
                } catch (e) { }
            }

            setInterval(pollMessages, 3000);
        </script>
        <% } %>

            <%- include('partials/footer') %>