<%- include('partials/header') %>

  <div
    style="background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); padding: 2rem; border-radius: var(--border-radius); border: var(--glass-border); margin-bottom: 3rem;">
    <h1 style="margin-bottom: 2rem;">Admin Dashboard</h1>

    <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
      <div
        style="flex: 1; min-width: 250px; background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); color: white; padding: 2rem; border-radius: var(--border-radius); text-align: center; box-shadow: 0 10px 20px rgba(108, 92, 231, 0.3);">
        <h2 style="font-size: 1.2rem; opacity: 0.9;">Total Users</h2>
        <p style="font-size: 3rem; font-weight: bold; margin-top: 0.5rem;">
          <%= profiles.length %>
        </p>
      </div>
      <div
        style="flex: 1; min-width: 250px; background: linear-gradient(135deg, var(--accent-color), #ff9ff3); color: white; padding: 2rem; border-radius: var(--border-radius); text-align: center; box-shadow: 0 10px 20px rgba(253, 121, 168, 0.3);">
        <h2 style="font-size: 1.2rem; opacity: 0.9;">Total Stories</h2>
        <p style="font-size: 3rem; font-weight: bold; margin-top: 0.5rem;">
          <%= posts.length %>
        </p>
      </div>
    </div>
  </div>

  <h2 style="margin-bottom: 1.5rem;">Manage Users</h2>

  <div class="posts-grid">
    <% profiles.forEach((profile)=> { %>
      <div class="post-card" style="padding: 1.5rem; text-align: center;">
        <img src="/thumbnails/<%= profile.dp %>" alt="User"
          onerror="this.onerror=null; this.src='https://source.unsplash.com/random/100x100?face'"
          style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin-bottom: 1rem;">
        <div class="card-title">@<%= profile.username %>
        </div>
        <p style="color: var(--text-light); margin-bottom: 1.5rem;">
          <%= profile.email %>
        </p>
        <a href="/removeuser/<%= profile._id %>" class="submit-btn"
          style="background: #ff7675; padding: 0.5rem 1rem; font-size: 0.9rem; width: 100%; display: inline-block;">Remove
          User</a>
      </div>
      <% }) %>
  </div>

  <%- include('partials/footer') %>