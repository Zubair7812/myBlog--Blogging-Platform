<%- include('partials/header') %>

  <h1>Admin Dashboard</h1>

  <div style="display: flex; gap: 2rem; margin-bottom: 2rem;">
    <div class="post-card" style="padding: 2rem; flex: 1; text-align: center;">
      <h2>Total Users</h2>
      <p style="font-size: 2rem; font-weight: bold; color: var(--primary-color);">
        <%= profiles.length %>
      </p>
    </div>
    <div class="post-card" style="padding: 2rem; flex: 1; text-align: center;">
      <h2>Total Posts</h2>
      <p style="font-size: 2rem; font-weight: bold; color: var(--primary-color);">
        <%= posts.length %>
      </p>
    </div>
  </div>

  <h2>Manage Users</h2>

  <div class="posts-grid">
    <% profiles.forEach((profile)=> { %>
      <div class="post-card">
        <div class="card-content">
          <div class="card-title">@<%= profile.username %>
          </div>
          <p>
            <%= profile.email %>
          </p>
          <a href="/removeuser/<%= profile._id %>" style="color: #ff7675; margin-top: 1rem; display: block;">Remove
            User</a>
        </div>
      </div>
      <% }) %>
  </div>

  <%- include('partials/footer') %>