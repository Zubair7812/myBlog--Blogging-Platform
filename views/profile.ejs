<%- include('partials/header') %>

  <div class="profile-header">
    <img src="/thumbnails/<%= userdata.dp %>" class="profile-img" alt="Profile Picture"
      onerror="this.onerror=null; this.src='/images/user-icon.png'">
    <h1>
      <%= userdata.fullname %>
    </h1>
    <p>@<%= userdata.username %>
    </p>

    <% if(username===userdata.username) { %>
      <a href="/editprofile/<%= userdata.username %>"><button class="compose-btn" style="margin-top: 1rem;"><i
            class="fa-solid fa-cog"></i> Edit Profile</button></a>
      <% } %>

        <div style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 1rem;">
          <% if(userdata.facebook) { %><a href="<%= userdata.facebook %>"><i
                class="fa-brands fa-facebook fa-xl"></i></a>
            <% } %>
              <% if(userdata.twitter) { %><a href="<%= userdata.twitter %>"><i
                    class="fa-brands fa-twitter fa-xl"></i></a>
                <% } %>
                  <% if(userdata.instagram) { %><a href="<%= userdata.instagram %>"><i
                        class="fa-brands fa-instagram fa-xl"></i></a>
                    <% } %>
        </div>
  </div>

  <div style="margin-bottom: 2rem;">
    <h2>Stories by <%= userdata.fullname %>
    </h2>
  </div>

  <div class="posts-grid">
    <% if(posts.length> 0) { %>
      <% posts.forEach((post)=> { %>
        <div class="post-card">
          <a href="/posts/<%= post._id %>">
            <div class="img-container">
              <img src="/thumbnails/<%= post.thumbnail %>" alt="<%= post.title %>"
                onerror="this.onerror=null; this.src='/images/default-image.png'">
            </div>
            <div class="card-content">
              <div class="card-title">
                <%= post.title %>
              </div>
              <div class="card-footer">
                <span><i class="fa-solid fa-heart"></i>
                  <%= post.like %>
                </span>
                <span>
                  <%= new Date(post.date).toLocaleDateString() %>
                </span>
              </div>
            </div>
          </a>
        </div>
        <% }) %>
          <% } else { %>
            <p>No stories published yet.</p>
            <% } %>
  </div>

  <%- include('partials/footer') %>