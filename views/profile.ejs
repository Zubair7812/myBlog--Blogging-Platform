<%- include('partials/header') %>

  <div class="profile-container" style="max-width: 1000px; margin: 0 auto;">

    <!-- Cover Photo Area -->
    <div class="profile-cover"
      style="height: 250px; background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)); border-radius: 0 0 var(--border-radius) var(--border-radius); position: relative; margin-bottom: 5rem;">
      <!-- Profile Picture -->
      <div class="profile-avatar-container"
        style="position: absolute; bottom: -60px; left: 50px; display: flex; align-items: end; gap: 2rem;">
        <img src="/thumbnails/<%= userdata.dp %>" alt="Profile" onerror="this.src='/images/user-icon.png'"
          style="width: 160px; height: 160px; border-radius: 50%; border: 5px solid white; object-fit: cover; background: white;">

        <div style="margin-bottom: 1rem;">
          <h1 style="color: var(--text-color); margin-bottom: 0.2rem; font-size: 2.2rem;">
            <%= userdata.fullname %>
          </h1>
          <p style="color: var(--text-light); font-weight: 500;">@<%= userdata.username %>
          </p>
        </div>
      </div>
    </div>

    <div class="profile-layout" style="display: grid; grid-template-columns: 1fr 2.5fr; gap: 3rem; padding: 0 2rem;">

      <!-- Sidebar: Bio & Stats -->
      <aside class="profile-sidebar">
        <div style="margin-bottom: 2rem;">
          <p style="font-size: 1.1rem; line-height: 1.6; color: var(--text-color); margin-bottom: 1.5rem;">
            <%= userdata.bio || "Writer, Thinker, Storyteller." %>
          </p>

          <div
            style="display: flex; gap: 1.5rem; border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color); padding: 1rem 0; margin-bottom: 1.5rem;">
            <div style="text-align: center;">
              <span style="display: block; font-weight: 700; font-size: 1.2rem; color: var(--primary-color);">
                <%= posts.length %>
              </span>
              <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase;">Stories</span>
            </div>
            <div style="text-align: center;">
              <span id="followerCount"
                style="display: block; font-weight: 700; font-size: 1.2rem; color: var(--primary-color);">
                <%= userdata.followers ? userdata.followers.length : 0 %>
              </span>
              <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase;">Followers</span>
            </div>
            <div style="text-align: center;">
              <span style="display: block; font-weight: 700; font-size: 1.2rem; color: var(--primary-color);">
                <%= userdata.following ? userdata.following.length : 0 %>
              </span>
              <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase;">Following</span>
            </div>
          </div>

          <!-- Social Links -->
          <div style="display: flex; gap: 1rem;">
            <% if(userdata.facebook) { %><a href="<%= userdata.facebook %>" class="social-btn"><i
                  class="fa-brands fa-facebook"></i></a>
              <% } %>
                <% if(userdata.twitter) { %><a href="<%= userdata.twitter %>" class="social-btn"><i
                      class="fa-brands fa-twitter"></i></a>
                  <% } %>
                    <% if(userdata.instagram) { %><a href="<%= userdata.instagram %>" class="social-btn"><i
                          class="fa-brands fa-instagram"></i></a>
                      <% } %>
          </div>
        </div>

        <% if(username===userdata.username) { %>
          <a href="/editprofile/<%= userdata.username %>" class="submit-btn"
            style="display: block; text-align: center; background: white; color: var(--primary-color); border: 2px solid var(--primary-color);">Edit
            Profile</a>
          <% } else { %>
            <div style="display: flex; gap: 0.5rem;">
              <button id="followBtn" class="submit-btn"
                style="flex: 1; background: <%= userdata.followers && userdata.followers.includes(currentUserId) ? 'white' : 'var(--primary-color)' %>; color: <%= userdata.followers && userdata.followers.includes(currentUserId) ? 'var(--primary-color)' : 'white' %>; border: 1px solid var(--primary-color);">
                <%= userdata.followers && userdata.followers.includes(currentUserId) ? 'Unfollow' : 'Follow' %>
              </button>
              <a href="/chat/<%= userdata.username %>" class="submit-btn"
                style="background: var(--accent-color); color: white; border: none; padding: 0.8rem; display: flex; align-items: center; justify-content: center;"><i
                  class="fa-regular fa-paper-plane"></i></a>
            </div>
            <% } %>
      </aside>

      <!-- Main Content: Stories -->
      <main class="profile-content">
        <h3
          style="border-bottom: 2px solid var(--primary-color); padding-bottom: 0.5rem; margin-bottom: 2rem; display: inline-block;">
          Published Stories</h3>

        <% if(posts.length> 0) { %>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;">
            <% posts.forEach((post)=> { %>
              <div class="post-card"
                style="flex-direction: column; padding: 0; background: white; border-radius: var(--border-radius); box-shadow: var(--shadow-sm); overflow: hidden; border: none;">
                <div class="img-container" style="height: 180px; width: 100%;">
                  <img src="/thumbnails/<%= post.thumbnail %>" alt="<%= post.title %>"
                    onerror="this.src='https://source.unsplash.com/random/400x300?nature'">
                </div>
                <div class="card-content" style="padding: 1.5rem;">
                  <div class="card-meta" style="margin-bottom: 0.5rem;">
                    <%= new Date(post.date).toLocaleDateString() %>
                  </div>
                  <a href="/posts/<%= post._id %>">
                    <h4 style="font-size: 1.2rem; margin-bottom: 1rem;">
                      <%= post.title %>
                    </h4>
                  </a>
                  <div
                    style="display: flex; justify-content: space-between; align-items: center; color: var(--text-light); font-size: 0.9rem;">
                    <span><i class="fa-solid fa-heart" style="color: var(--accent-color);"></i>
                      <%= post.like %>
                    </span>
                    <a href="/posts/<%= post._id %>" style="color: var(--primary-color); font-weight: 700;">Read
                      &rarr;</a>
                  </div>
                </div>
              </div>
              <% }) %>
          </div>
          <% } else { %>
            <div style="text-align: center; padding: 3rem; background: #fff; border-radius: var(--border-radius);">
              <p>No stories published yet.</p>
            </div>
            <% } %>
      </main>
    </div>
  </div>

  <script>
    const followBtn = document.getElementById('followBtn');
    if (followBtn) {
      followBtn.addEventListener('click', async () => {
        const isFollowing = followBtn.innerText === 'Unfollow';
        const url = isFollowing ? '/unfollow/<%= userdata._id %>' : '/follow/<%= userdata._id %>';

        try {
          const res = await fetch(url, { method: 'POST' });
          const data = await res.json();

          if (data.status === 'followed') {
            followBtn.innerText = 'Unfollow';
            followBtn.style.background = 'white';
            followBtn.style.color = 'var(--primary-color)';
            document.getElementById('followerCount').innerText = data.followersCount;
          } else if (data.status === 'unfollowed') {
            followBtn.innerText = 'Follow';
            followBtn.style.background = 'var(--primary-color)';
            followBtn.style.color = 'white';
            document.getElementById('followerCount').innerText = data.followersCount;
          }
        } catch (err) { console.error(err); }
      });
    }
  </script>

  <%- include('partials/footer') %>