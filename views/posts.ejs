<%- include('partials/header') %>

  <div class="post-detail">
    <div class="post-header">
      <h1>
        <%= posts.title %>
      </h1>
      <div class="post-meta">
        <span>By <strong>
            <%= posts.author %>
          </strong></span>
        <span>
          <%= new Date(posts.date).toLocaleDateString() %>
        </span>
      </div>
    </div>

    <img src="/thumbnails/<%= posts.thumbnail %>" alt="<%= posts.title %>"
      onerror="this.onerror=null; this.src='/images/default-image.png'">

    <div class="post-content">
      <p style="white-space: pre-wrap;">
        <%= posts.content %>
      </p>
    </div>

    <div style="margin-top: 3rem; display: flex; gap: 1rem; align-items: center;">
      <button id="likeBtn" class="compose-btn"
        style="background: <%= posts.likedby.includes(user) ? '#ff7675' : '#6c5ce7' %>">
        <i class="fa-solid fa-heart"></i> <span id="likeCount">
          <%= posts.like %>
        </span> Likes
      </button>

      <% if(user===posts.author || userType==='admin' ) { %>
        <a href="/update/<%= posts._id %>" style="color: var(--text-light);"><i class="fa-solid fa-edit"></i> Edit</a>
        <a href="/delete/<%= posts._id %>" style="color: #ff7675;"><i class="fa-solid fa-trash"></i> Delete</a>
        <% } %>
    </div>
  </div>

  <script>
    document.getElementById('likeBtn').addEventListener('click', async () => {
      try {
        const res = await fetch('/posts/<%= posts._id %>/like', { method: 'POST' });
        const data = await res.json();

        const likeCount = document.getElementById('likeCount');
        const btn = document.getElementById('likeBtn');
        let currentLikes = parseInt(likeCount.innerText);

        if (data.status === 'liked') {
          likeCount.innerText = currentLikes + 1;
          btn.style.background = '#ff7675';
        } else {
          likeCount.innerText = currentLikes - 1;
          btn.style.background = '#6c5ce7';
        }
      } catch (err) {
        console.error('Error liking post', err);
      }
    });
  </script>

  <%- include('partials/footer') %>