<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - myBlog</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body style="display: flex; justify-content: center; align-items: center; min-height: 100vh;">

    <div class="auth-wrapper">
        <!-- Decoration Side -->
        <div class="auth-side-img">
            <div class="login-logo-container" style="position: absolute; top: 2rem; left: 2rem;">
                <img src="/images/logo.png" alt="myBlog Logo" class="login-logo" style="max-width: 120px;">
            </div>
            <div class="side-content">
                <h2 id="side-title" style="margin-bottom: 1rem; font-size: 2rem;">Welcome Back</h2>
                <p id="side-text" style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 2rem;">"There is no greater
                    agony than bearing an untold story inside you."</p>
                <div style="font-size: 0.9rem; font-style: italic; opacity: 0.7;">— Maya Angelou</div>
            </div>
        </div>

        <!-- Form Side -->
        <div class="auth-content" id="login-box">
            <h2 style="color: var(--primary-color); margin-bottom: 2rem; font-size: 2rem;">Sign In</h2>
            <form action="/login" method="post">
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" placeholder="name@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="submit-btn" style="width: 100%; margin-top: 1rem;">Login</button>
            </form>
            <p style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem;">
                New to myBlog? <a onclick="toggleAuth()"
                    style="color: var(--secondary-color); font-weight: 700; cursor: pointer;">Join the Community</a>
            </p>
        </div>

        <!-- Signup Form (Hidden initially) -->
        <div class="auth-content" id="signup-box" style="display: none;">
            <h2 style="color: var(--primary-color); margin-bottom: 2rem; font-size: 2rem;">Join Us</h2>
            <form action="/signup" method="post">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="name" placeholder="Author Name" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" placeholder="name@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="submit-btn" style="width: 100%; margin-top: 1rem;">Start Writing</button>
            </form>
            <p style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem;">
                Already a member? <a onclick="toggleAuth()"
                    style="color: var(--secondary-color); font-weight: 700; cursor: pointer;">Sign In</a>
            </p>
        </div>
    </div>

    <script>
        function toggleAuth() {
            const loginBox = document.getElementById('login-box');
            const signupBox = document.getElementById('signup-box');
            const sideTitle = document.getElementById('side-title');
            const sideText = document.getElementById('side-text');

            if (loginBox.style.display === 'none') {
                // Switch to Login View
                loginBox.style.display = 'block';
                signupBox.style.display = 'none';
                sideTitle.innerText = "Welcome Back";
                sideText.innerText = '"There is no greater agony than bearing an untold story inside you."';
            } else {
                // Switch to Signup View
                loginBox.style.display = 'none';
                signupBox.style.display = 'block';
                sideTitle.innerText = "Begin Your Journey";
                sideText.innerText = '"Start writing, no matter what. The water does not flow until the faucet is turned on."';
            }
        }
    </script>
</body>

</html>