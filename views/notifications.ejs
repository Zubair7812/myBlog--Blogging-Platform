<%- include('partials/header') %>

    <div style="max-width: 800px; margin: 4rem auto; padding: 0 2rem;">
        <h1 style="border-bottom: 2px solid var(--primary-color); padding-bottom: 1rem; margin-bottom: 2rem;">
            Notifications</h1>

        <div class="notifications-list">
            <% if(notifications.length> 0) { %>
                <% notifications.forEach(notif=> { %>
                    <div class="notification-card"
                        style="display: flex; align-items: center; background: white; padding: 1.5rem; border-radius: var(--border-radius); border-bottom: 1px solid var(--border-color); margin-bottom: 1rem; transition: background 0.3s;">
                        <img src="/thumbnails/<%= notif.sender.dp %>" onerror="this.src='/images/user-icon.png'"
                            style="width: 50px; height: 50px; border-radius: 50%; margin-right: 1.5rem; object-fit: cover;">

                        <div style="flex: 1;">
                            <p style="margin-bottom: 0.3rem; font-size: 1.1rem;">
                                <a href="/profile/<%= notif.sender.username %>"
                                    style="font-weight: 700; color: var(--primary-color);">
                                    <%= notif.sender.username %>
                                </a>

                                <% if(notif.type==='like' ) { %>
                                    liked your story <a href="/posts/<%= notif.postId._id %>"
                                        style="font-style: italic; color: var(--text-color);">
                                        <%= notif.postId.title %>
                                    </a>
                                    <% } else if(notif.type==='comment' ) { %>
                                        commented on your story <a href="/posts/<%= notif.postId._id %>"
                                            style="font-style: italic; color: var(--text-color);">
                                            <%= notif.postId.title %>
                                        </a>
                                        <% } else if(notif.type==='follow' ) { %>
                                            started following you
                                            <% } %>
                            </p>
                            <span style="font-size: 0.85rem; color: var(--text-light);">
                                <%= new Date(notif.createdAt).toLocaleDateString() %>
                            </span>
                        </div>

                        <% if(!notif.read) { %>
                            <div
                                style="width: 10px; height: 10px; background: var(--accent-color); border-radius: 50%;">
                            </div>
                            <% } %>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div style="text-align: center; padding: 4rem; color: var(--text-light);">
                                <i class="fa-regular fa-bell"
                                    style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
                                <p>No new notifications yet.</p>
                            </div>
                            <% } %>
        </div>
    </div>

    <%- include('partials/footer') %>