<%- include('partials/header') %>

    <div class="form-container">
        <h1 style="margin-bottom: 2rem; text-align: center; color: var(--primary-color);">Create Your Masterpiece</h1>

        <form action="/compose" method="post" enctype="multipart/form-data">
            <div class="form-group">
                <label><i class="fa-solid fa-heading"></i> Title</label>
                <input type="text" name="postTitle" placeholder="Enter a catchy title..." required>
            </div>

            <div class="form-group">
                <label><i class="fa-solid fa-image"></i> Cover Image</label>
                <input type="file" name="image" accept="image/*" style="padding: 0.5rem; background: white;">
            </div>

            <div class="form-group">
                <label><i class="fa-solid fa-pen-fancy"></i> Story Content</label>
                <textarea name="postBody" rows="15" placeholder="Tell your story..." required></textarea>
            </div>

            <button type="submit" class="submit-btn" style="width: 100%; margin-top: 1rem;"><i
                    class="fa-solid fa-paper-plane"></i> Publish Story</button>
        </form>
    </div>

    <%- include('partials/footer') %>