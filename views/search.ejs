<%- include('partials/header') %>

    <div style="max-width: 800px; margin: 0 auto;">
        <h1 style="margin-bottom: 2rem;">Search Results for "<span style="color: var(--accent-color);">
                <%= query %>
            </span>"</h1>

        <div style="margin-bottom: 2rem; border-bottom: 1px solid var(--border-color);">
            <a href="/search?q=<%= query %>&filter=all"
                style="margin-right: 1.5rem; font-weight: 700; color: <%= filter === 'all' ? 'var(--primary-color)' : 'var(--text-light)' %>; border-bottom: <%= filter === 'all' ? '3px solid var(--primary-color)' : 'none' %>; padding-bottom: 0.5rem; display: inline-block;">All</a>
            <a href="/search?q=<%= query %>&filter=posts"
                style="margin-right: 1.5rem; font-weight: 700; color: <%= filter === 'posts' ? 'var(--primary-color)' : 'var(--text-light)' %>; border-bottom: <%= filter === 'posts' ? '3px solid var(--primary-color)' : 'none' %>; padding-bottom: 0.5rem; display: inline-block;">Stories</a>
            <a href="/search?q=<%= query %>&filter=people"
                style="font-weight: 700; color: <%= filter === 'people' ? 'var(--primary-color)' : 'var(--text-light)' %>; border-bottom: <%= filter === 'people' ? '3px solid var(--primary-color)' : 'none' %>; padding-bottom: 0.5rem; display: inline-block;">People</a>
        </div>

        <% if (users.length===0 && posts.length===0) { %>
            <div style="text-align: center; padding: 3rem; color: var(--text-light);">
                <i class="fa-regular fa-face-frown" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                <p>We couldn't find anything matching your search.</p>
            </div>
            <% } %>

                <% if (users.length> 0) { %>
                    <h3 style="margin-bottom: 1rem;">People</h3>
                    <div class="posts-grid" style="margin-bottom: 3rem;">
                        <% users.forEach(u=> { %>
                            <div class="post-card"
                                style="padding: 1rem; align-items: center; background: #fff; border: 1px solid #eee; border-radius: 8px;">
                                <img src="/thumbnails/<%= u.dp %>" onerror="this.src='/images/user-icon.png'"
                                    style="width: 50px; height: 50px; border-radius: 50%; margin-right: 1rem;">
                                <div>
                                    <a href="/profile/<%= u.username %>" style="font-weight: 700; font-size: 1.1rem;">@
                                        <%= u.username %></a>
                                    <p style="font-size: 0.9rem; color: var(--text-light);">
                                        <%= u.fullname %>
                                    </p>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>

                        <% if (posts.length> 0) { %>
                            <h3 style="margin-bottom: 1rem;">Stories</h3>
                            <% posts.forEach(post=> { %>
                                <div class="post-card">
                                    <div class="img-container" style="flex: 0 0 200px; height: 140px;">
                                        <a href="/posts/<%= post._id %>">
                                            <img src="/thumbnails/<%= post.thumbnail %>" alt="<%= post.title %>">
                                        </a>
                                    </div>
                                    <div class="card-content">
                                        <a href="/posts/<%= post._id %>">
                                            <h2 class="card-title" style="font-size: 1.3rem;">
                                                <%= post.title %>
                                            </h2>
                                        </a>
                                        <p class="card-excerpt" style="margin-bottom: 0.5rem;">
                                            <%= post.content.substring(0, 100) %>...
                                        </p>
                                        <div class="card-meta">By <%= post.author %>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } %>

    </div>

    <%- include('partials/footer') %>