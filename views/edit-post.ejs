<%- include('partials/header') %>

    <div class="form-container">
        <h1 style="text-align: center; margin-bottom: 2rem;">Update Story</h1>
        <form action="/update/<%= post._id %>" method="post" enctype="multipart/form-data">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="postTitle" value="<%= post.title %>" required>
            </div>

            <div class="form-group">
                <label>Update Cover Image</label>
                <input type="file" name="image" style="padding: 0.5rem; background: white;">
            </div>

            <div class="form-group">
                <label>Content</label>
                <textarea name="postBody" rows="15" required><%= post.content %></textarea>
            </div>

            <button type="submit" class="submit-btn" style="width: 100%; margin-top: 1rem;"><i
                    class="fa-solid fa-save"></i> Save Updates</button>
        </form>
    </div>

    <%- include('partials/footer') %>