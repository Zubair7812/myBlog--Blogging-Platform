<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Daily Blog - Editorial</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body>
    <nav>
        <div class="logo">
            <a href="/home">
                <img src="/images/logo.png" alt="myBlog Logo">
            </a>
        </div>

        <div class="nav-center">
            <form action="/search" method="get" class="nav-search">
                <input type="text" name="q" placeholder="Search stories, people, or topics...">
                <button type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
            </form>
        </div>

        <div class="nav-items">
            <ul>
                <% if(typeof user !=='undefined' && user) { %>
                    <li>
                        <a href="/chat" title="Messages" class="chat-btn-nav" style="position: relative;">
                            <i class="fa-regular fa-paper-plane" style="font-size: 1rem;"></i>
                            <span id="chat-badge" class="badge" style="display: none;"></span>
                        </a>
                    </li>
                    <li>
                        <a href="/notifications" style="position: relative;">
                            <i class="fa-regular fa-bell" style="font-size: 1.2rem;"></i>
                            <span id="notif-badge"
                                style="display: none; position: absolute; top: -5px; right: -5px; background: var(--accent-color); color: white; border-radius: 50%; width: 8px; height: 8px;"></span>
                        </a>
                    </li>
                    <li><a href="/compose">Write Story</a></li>
                    <% if(typeof userType !=='undefined' && userType==='admin' ) { %>
                        <li><a href="/admin">Admin</a></li>
                        <% } else { %>
                            <li><a href="/profile/<%= user %>">Profile</a></li>
                            <% } %>
                                <li><a href="/logout">Logout</a></li>
                                <% } else { %>
                                    <li><a href="/" class="compose-btn"
                                            style="padding: 0.5rem 1.5rem; font-size: 0.8rem;">Login</a></li>
                                    <% } %>
            </ul>
        </div>
    </nav>

    <script>
        // Check for notifications
        <% if (typeof user !== 'undefined' && user) { %>
            async function updateUnreadCount() {
                try {
                    const res = await fetch('/api/chat/unread-count');
                    const data = await res.json();

                    const chatBadge = document.getElementById('chat-badge');
                    if (chatBadge) {
                        if (data.count > 0) {
                            chatBadge.innerText = data.count > 99 ? '99+' : data.count;
                            chatBadge.style.display = 'flex';
                        } else {
                            chatBadge.style.display = 'none';
                        }
                    }
                } catch (e) { console.error(e); }
            }

            // Initial check
            updateUnreadCount();
            setInterval(updateUnreadCount, 5000); // Poll every 5s for unread count

            // Notification polling
            async function checkNotifications() {
                try {
                    const res = await fetch('/api/notifications/unread');
                    const data = await res.json();
                    const badge = document.getElementById('notif-badge');
                    if (data.count > 0 && badge) {
                        badge.style.display = 'block';
                    }
                } catch (e) { }
            }
            checkNotifications();
            setInterval(checkNotifications, 60000);
        <% } %>
    </script>
    <main>